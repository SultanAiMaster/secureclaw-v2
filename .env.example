# Razorpay Payment Gateway
# Get keys from: https://dashboard.razorpay.com/#/app/keys

# Public Key (safe to expose)
NEXT_PUBLIC_RAZORPAY_KEY_ID=your_key_id_here

# Secret Key (NEVER commit this - only for server-side)
RAZORPAY_KEY_SECRET=your_secret_key_here

# API base URL
NEXT_PUBLIC_API_URL=https://yourdomain.com

# Environment (development | production)
NODE_ENV=production

# Database (optional - using in-memory for now)
DATABASE_URL=your_database_connection_string

# For local testing, use test keys from Razorpay:
# NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_demo_key
# RAZORPAY_KEY_SECRET=test_key_secret